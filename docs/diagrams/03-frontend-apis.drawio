<mxfile host="Claude">
  <diagram name="Frontend y APIs" id="frontend-apis">
    <mxGraphModel adaptiveColors="auto" dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- TITLE -->
        <mxCell id="title" value="SmartWaste MVD — Frontends y APIs" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=20;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="200" y="20" width="1000" height="40" as="geometry" />
        </mxCell>

        <!-- ============================ -->
        <!-- REST API LANE                -->
        <!-- ============================ -->
        <mxCell id="lane_rest" value="REST API — Dashboard de Operaciones" style="swimlane;startSize=35;fillColor=#E8F5E9;strokeColor=#2E7D32;fontStyle=1;fontSize=13;fontColor=#1B5E20;" vertex="1" parent="1">
          <mxGeometry x="30" y="80" width="1560" height="270" as="geometry" />
        </mxCell>

        <!-- Dashboard React app -->
        <mxCell id="dash" value="Dashboard Ops&#xa;React + Leaflet + Recharts&#xa;(despachadores / supervisores)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#232F3E;strokeColor=#555;fontColor=#ffffff;fontSize=11;" vertex="1" parent="lane_rest">
          <mxGeometry x="50" y="90" width="170" height="80" as="geometry" />
        </mxCell>

        <!-- REST API GW -->
        <mxCell id="rest_gw" value="API Gateway REST&#xa;https://&lt;API_ID&gt;...&#xa;/dev" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.api_gateway;fillColor=#CC2264;strokeColor=none;fontColor=#232F3E;fontSize=11;labelPosition=center;verticalLabelPosition=bottom;verticalAlign=top;" vertex="1" parent="lane_rest">
          <mxGeometry x="360" y="80" width="60" height="60" as="geometry" />
        </mxCell>

        <!-- Lambda api -->
        <mxCell id="lam_api" value="Lambda api&#xa;(DynamoDB reads)" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda;fillColor=#FF9900;strokeColor=none;fontColor=#232F3E;fontSize=11;labelPosition=center;verticalLabelPosition=bottom;verticalAlign=top;" vertex="1" parent="lane_rest">
          <mxGeometry x="590" y="80" width="60" height="60" as="geometry" />
        </mxCell>

        <!-- DynamoDB -->
        <mxCell id="dyn_rest" value="DynamoDB&#xa;containers / routes / trucks" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.dynamodb;fillColor=#3F48CC;strokeColor=none;fontColor=#232F3E;fontSize=11;labelPosition=center;verticalLabelPosition=bottom;verticalAlign=top;" vertex="1" parent="lane_rest">
          <mxGeometry x="820" y="80" width="60" height="60" as="geometry" />
        </mxCell>

        <!-- Endpoints note -->
        <mxCell id="ep_note" value="GET /containers&#xa;GET /containers/{id}&#xa;GET /circuits&#xa;GET /circuits/{id}/route&#xa;POST /circuits/{id}/optimize&#xa;GET /trucks" style="text;html=1;strokeColor=#CC2264;fillColor=#fce4ec;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;" vertex="1" parent="lane_rest">
          <mxGeometry x="1050" y="60" width="160" height="120" as="geometry" />
        </mxCell>

        <!-- REST Arrows -->
        <mxCell id="e_dash_gw" value="HTTPS REST" style="edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="dash" target="rest_gw" parent="lane_rest">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_gw_lam" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="rest_gw" target="lam_api" parent="lane_rest">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_lam_dyn" value="Query / Scan" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="lam_api" target="dyn_rest" parent="lane_rest">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Optimize button flow -->
        <mxCell id="lam_ro" value="Lambda&#xa;route-optimizer&#xa;(invocación manual)" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda;fillColor=#FF9900;strokeColor=none;fontColor=#232F3E;fontSize=11;labelPosition=center;verticalLabelPosition=bottom;verticalAlign=top;" vertex="1" parent="lane_rest">
          <mxGeometry x="590" y="170" width="60" height="60" as="geometry" />
        </mxCell>
        <mxCell id="e_lam_ro" value="POST /optimize&#xa;→ InvokeFunction" style="edgeStyle=orthogonalEdgeStyle;rounded=1;dashed=1;" edge="1" source="lam_api" target="lam_ro" parent="lane_rest">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ============================ -->
        <!-- WEBSOCKET LANE               -->
        <!-- ============================ -->
        <mxCell id="lane_ws" value="WebSocket API — App del Conductor" style="swimlane;startSize=35;fillColor=#E3F2FD;strokeColor=#1565C0;fontStyle=1;fontSize=13;fontColor=#0D47A1;" vertex="1" parent="1">
          <mxGeometry x="30" y="370" width="1560" height="360" as="geometry" />
        </mxCell>

        <!-- Driver App -->
        <mxCell id="driver" value="Driver App&#xa;React PWA&#xa;(conductor en móvil)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#232F3E;strokeColor=#555;fontColor=#ffffff;fontSize=11;" vertex="1" parent="lane_ws">
          <mxGeometry x="50" y="120" width="170" height="80" as="geometry" />
        </mxCell>

        <!-- WS API GW -->
        <mxCell id="ws_gw" value="API Gateway WS&#xa;wss://&lt;WS_API_ID&gt;...&#xa;/dev" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.api_gateway;fillColor=#CC2264;strokeColor=none;fontColor=#232F3E;fontSize=11;labelPosition=center;verticalLabelPosition=bottom;verticalAlign=top;" vertex="1" parent="lane_ws">
          <mxGeometry x="360" y="110" width="60" height="60" as="geometry" />
        </mxCell>

        <!-- Lambda ws-connect -->
        <mxCell id="lam_conn" value="Lambda&#xa;ws-connect" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda;fillColor=#FF9900;strokeColor=none;fontColor=#232F3E;fontSize=11;labelPosition=center;verticalLabelPosition=bottom;verticalAlign=top;" vertex="1" parent="lane_ws">
          <mxGeometry x="590" y="50" width="60" height="60" as="geometry" />
        </mxCell>

        <!-- Lambda ws-disconnect -->
        <mxCell id="lam_disc" value="Lambda&#xa;ws-disconnect" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda;fillColor=#FF9900;strokeColor=none;fontColor=#232F3E;fontSize=11;labelPosition=center;verticalLabelPosition=bottom;verticalAlign=top;" vertex="1" parent="lane_ws">
          <mxGeometry x="590" y="140" width="60" height="60" as="geometry" />
        </mxCell>

        <!-- Lambda ws-message -->
        <mxCell id="lam_msg" value="Lambda&#xa;ws-message" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda;fillColor=#FF9900;strokeColor=none;fontColor=#232F3E;fontSize=11;labelPosition=center;verticalLabelPosition=bottom;verticalAlign=top;" vertex="1" parent="lane_ws">
          <mxGeometry x="590" y="230" width="60" height="60" as="geometry" />
        </mxCell>

        <!-- DynamoDB connections -->
        <mxCell id="dyn_conn" value="DynamoDB&#xa;connections&#xa;{connectionId, truckId, circuitId}" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.dynamodb;fillColor=#3F48CC;strokeColor=none;fontColor=#232F3E;fontSize=11;labelPosition=center;verticalLabelPosition=bottom;verticalAlign=top;" vertex="1" parent="lane_ws">
          <mxGeometry x="830" y="110" width="60" height="60" as="geometry" />
        </mxCell>

        <!-- DynamoDB containers update -->
        <mxCell id="dyn_cont_ws" value="DynamoDB&#xa;containers&#xa;fill_level = 0" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.dynamodb;fillColor=#3F48CC;strokeColor=none;fontColor=#232F3E;fontSize=11;labelPosition=center;verticalLabelPosition=bottom;verticalAlign=top;" vertex="1" parent="lane_ws">
          <mxGeometry x="830" y="230" width="60" height="60" as="geometry" />
        </mxCell>

        <!-- route-optimizer notifier -->
        <mxCell id="ro_notif" value="route-optimizer&#xa;ws_notifier.notify()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#5d4037;fontSize=11;fontStyle=2;" vertex="1" parent="lane_ws">
          <mxGeometry x="1080" y="110" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- WS message examples -->
        <mxCell id="ws_msgs" value='Driver → Server:&#xa;{"action":"container_emptied","container_id":"12345"}&#xa;&#xa;Server → Driver:&#xa;{"type":"route_update","circuit_id":"...","stops":42,"distance_km":18.3}' style="text;html=1;strokeColor=#1565C0;fillColor=#bbdefb;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;" vertex="1" parent="lane_ws">
          <mxGeometry x="50" y="250" width="280" height="80" as="geometry" />
        </mxCell>

        <!-- WS Arrows -->
        <mxCell id="e_drv_ws" value="$connect" style="edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=1;exitY=0.3;exitDx=0;exitDy=0;entryX=0;entryY=0.3;entryDx=0;entryDy=0;" edge="1" source="driver" target="ws_gw" parent="lane_ws">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_drv_ws2" value="$default" style="edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=1;exitY=0.7;exitDx=0;exitDy=0;entryX=0;entryY=0.7;entryDx=0;entryDy=0;" edge="1" source="driver" target="ws_gw" parent="lane_ws">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_ws_conn" value="$connect" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="ws_gw" target="lam_conn" parent="lane_ws">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_ws_disc" value="$disconnect" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="ws_gw" target="lam_disc" parent="lane_ws">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_ws_msg" value="$default" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="ws_gw" target="lam_msg" parent="lane_ws">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_conn_dyn" value="PutItem / DeleteItem&#xa;connectionId" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="lam_conn" target="dyn_conn" parent="lane_ws">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_msg_dyn" value="fill_level=0&#xa;needs_collection=False" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="lam_msg" target="dyn_cont_ws" parent="lane_ws">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Reverse: route_update back to driver -->
        <mxCell id="e_ro_ws_back" value="POST @connections/{id}&#xa;route_update" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#E7157B;fontColor=#E7157B;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.3;entryDx=0;entryDy=0;" edge="1" source="ro_notif" target="ws_gw" parent="lane_ws">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_ws_drv_back" value="route_update" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#E7157B;fontColor=#E7157B;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="ws_gw" target="driver" parent="lane_ws">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
