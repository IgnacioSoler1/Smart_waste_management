# Copiar a .env.local y completar con los valores del terraform output

# URL base de la REST API (sin trailing slash)
# terraform output api_url
VITE_API_URL=https://YOUR_API_ID.execute-api.us-east-1.amazonaws.com/dev

# URL del WebSocket API (wss://)
# terraform output websocket_url
VITE_WS_URL=wss://YOUR_WS_ID.execute-api.us-east-1.amazonaws.com/dev
